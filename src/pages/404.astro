---
import Base from "../layouts/Base.astro";
---

<Base title="Not found | Vignesh Gopalakrishnan" description="The requested page could not be found.">
  <section class="shell py-24">
    <p class="eyebrow">404</p>
    <h1 class="mt-4 text-4xl font-semibold">This page is not here.</h1>
    <p class="mt-4 max-w-xl text-stone-700">
      The site is small on purpose. Start at the home page or browse the essays.
    </p>
    <div class="mt-8 flex flex-wrap gap-4">
      <a class="focus-ring font-semibold no-underline" href="/">Home</a>
      <a class="focus-ring font-semibold no-underline" href="/essays/">Essays</a>
    </div>
  </section>
</Base>
