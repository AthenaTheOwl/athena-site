---
import Footer from "../components/Footer.astro";
import Nav from "../components/Nav.astro";
import "../styles/globals.css";

interface Props {
  title?: string;
  description?: string;
}

const {
  title = "Vignesh Gopalakrishnan | Athena Site",
  description = "Portfolio doors, essays, and a semiconductor supply-chain map from Vignesh Gopalakrishnan."
} = Astro.props;

const canonical = new URL(Astro.url.pathname, Astro.site ?? "https://athena-site.vercel.app");
---

<!doctype html>
<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1" />
    <title>{title}</title>
    <meta name="description" content={description} />
    <link rel="canonical" href={canonical} />
    <link rel="icon" href="/favicon.svg" type="image/svg+xml" />
    <meta property="og:type" content="website" />
    <meta property="og:title" content={title} />
    <meta property="og:description" content={description} />
    <meta property="og:url" content={canonical} />
    <meta property="og:image" content="/og-default.png" />
    <meta name="twitter:card" content="summary_large_image" />
    <meta name="twitter:title" content={title} />
    <meta name="twitter:description" content={description} />
    <meta name="twitter:image" content="/og-default.png" />
  </head>
  <body class="min-h-screen">
    <Nav />
    <main>
      <slot />
    </main>
    <Footer />
  </body>
</html>
