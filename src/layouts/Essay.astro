---
import Base from "./Base.astro";

const { frontmatter } = Astro.props;
const title = `${frontmatter.title} | Vignesh Gopalakrishnan`;
const description = frontmatter.description;
---

<Base title={title} description={description}>
  <article class="shell py-12 sm:py-16">
    <a href="/essays/" class="focus-ring inline-flex text-sm font-medium no-underline">Back to essays</a>
    <header class="mt-10 max-w-3xl border-b border-line pb-8">
      <p class="eyebrow">Essay</p>
      <h1 class="mt-4 text-4xl font-semibold leading-tight sm:text-5xl">{frontmatter.title}</h1>
      <p class="mt-5 text-lg leading-8 text-stone-700">{frontmatter.description}</p>
      <div class="mt-6 flex flex-wrap gap-3 font-mono text-xs uppercase tracking-[0.16em] text-stone-500">
        <span>{frontmatter.date}</span>
        <span>{frontmatter.readingTime}</span>
      </div>
    </header>
    <div class="prose prose-stone mt-10 max-w-3xl prose-a:text-accent prose-a:no-underline hover:prose-a:underline prose-headings:font-semibold prose-p:leading-8">
      <slot />
    </div>
  </article>
</Base>
