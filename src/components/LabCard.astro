---
interface Repo {
  name: string;
  domain: string;
  maturity: "flagship" | "active" | "lab" | "archive";
  hook: string;
  github: string;
  live: string | null;
  deploy_target: string;
  demo_cmd?: string | null;
}

const { repo, live, degree } = Astro.props as { repo: Repo; live: string | null; degree: number };

const maturityStyles: Record<string, string> = {
  flagship: "border-accent text-accent",
  active: "border-emerald-700 text-emerald-800",
  lab: "border-amber-700 text-amber-800",
  archive: "border-stone-300 text-stone-500",
};
---

<article
  class="lab-card flex min-h-56 flex-col justify-between border border-line bg-white p-5"
  data-maturity={repo.maturity}
  data-domain={repo.domain}
>
  <div>
    <div class="flex items-start justify-between gap-3">
      <h3 class="break-words text-lg font-semibold leading-6">
        <a class="focus-ring no-underline" href={repo.github} target="_blank" rel="noreferrer">{repo.name}</a>
      </h3>
      <span class:list={["shrink-0 rounded-full border px-2.5 py-1 font-mono text-[0.6rem] uppercase tracking-[0.14em]", maturityStyles[repo.maturity]]}>
        {repo.maturity}
      </span>
    </div>
    <p class="mt-3 text-sm leading-6 text-stone-700">{repo.hook}</p>
  </div>
  <div class="mt-5 flex flex-wrap items-center gap-x-4 gap-y-2 border-t border-line pt-3 text-sm">
    {live ? (
      <a class="focus-ring inline-flex font-semibold text-accent no-underline" href={live} target="_blank" rel="noreferrer">
        live demo &rarr;
      </a>
    ) : (
      repo.deploy_target === "streamlit" || repo.deploy_target === "vercel" ? (
        <span class="font-mono text-xs uppercase tracking-[0.12em] text-stone-400">deploy: {repo.deploy_target}</span>
      ) : null
    )}
    <a class="focus-ring inline-flex font-semibold no-underline" href={repo.github} target="_blank" rel="noreferrer">
      code &rarr;
    </a>
    {degree > 0 && (
      <span class="ml-auto font-mono text-[0.65rem] uppercase tracking-[0.12em] text-stone-400">{degree} link{degree === 1 ? "" : "s"}</span>
    )}
  </div>
</article>
