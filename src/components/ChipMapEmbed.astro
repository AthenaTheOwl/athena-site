---
const url = "https://chip-supply-chain-map.vercel.app";
const source = "https://github.com/AthenaTheOwl/chip-supply-chain-map";
---

<section id="chip-map" class="shell py-14 sm:py-16">
  <div class="max-w-3xl">
    <p class="eyebrow">Flagship demo</p>
    <h2 class="mt-3 text-3xl font-semibold sm:text-4xl">Chip supply-chain map</h2>
    <p class="mt-4 text-stone-700">
      A dependency graph view of foundries, OSATs, equipment, substrates, EDA, hyperscalers, and chokepoints.
    </p>
  </div>
  <div class="mt-8 overflow-hidden border border-line bg-white">
    <div class="relative aspect-video w-full bg-stone-100">
      <iframe
        id="chip-map-frame"
        src={url}
        class="h-full w-full"
        loading="lazy"
        title="Chip supply chain map"
      ></iframe>
      <div
        id="chip-map-fallback"
        class="hidden absolute inset-0 grid place-items-center bg-white p-4 text-center"
        aria-live="polite"
      >
        <div class="max-w-lg">
          <img
            src="/screenshots/chip-map-placeholder.svg"
            alt="Static preview of a semiconductor supply-chain dependency map"
            class="mx-auto w-full border border-line"
            loading="lazy"
          />
          <p class="mt-4 text-sm text-stone-600">
            The embedded map is still coming online. Open it in a new tab or view the source repository.
          </p>
        </div>
      </div>
    </div>
    <p class="border-t border-line px-4 py-3 text-sm text-stone-500">
      flagship demo |
      <a href={url} target="_blank" rel="noreferrer">open in new tab</a>
      |
      <a href={source} target="_blank" rel="noreferrer">source</a>
    </p>
  </div>
</section>

<script>
  const frame = document.querySelector<HTMLIFrameElement>("#chip-map-frame");
  const fallback = document.querySelector<HTMLElement>("#chip-map-fallback");
  let loaded = false;

  frame?.addEventListener("load", () => {
    loaded = true;
  });

  window.setTimeout(() => {
    if (!loaded) {
      fallback?.classList.remove("hidden");
    }
  }, 3200);
</script>
