---
import qaIndex from "../data/factory-qa-index.json";

const cannedQuestions = [
  "what should we build next",
  "which repos have CDCP",
  "what are the new factory repos",
  "what credentials are blocked",
  "what is MCP Security Lab"
];

const serializedIndex = JSON.stringify(qaIndex).replace(/</g, "\\u003c");
---

<section class="border-b border-line bg-paper py-12 sm:py-16">
  <div class="shell">
    <div>
      <div>
        <p class="eyebrow">Factory Q&A</p>
        <h2 class="mt-3 text-3xl font-semibold sm:text-4xl">Ask the control tower</h2>
      </div>
    </div>

    <div data-factory-qa class="mt-8 grid gap-5 lg:grid-cols-[0.8fr_1.2fr]">
      <form data-qa-form class="border border-line bg-white p-5">
        <label class="font-mono text-xs uppercase tracking-[0.16em] text-stone-500" for="factory-question">
          Question
        </label>
        <div class="mt-3 flex flex-col gap-2 sm:flex-row">
          <input
            id="factory-question"
            data-qa-input
            class="focus-ring min-h-11 flex-1 border border-line px-3 py-2 text-base"
            name="question"
            placeholder="what should we build next"
            type="search"
          />
          <button
            class="focus-ring min-h-11 border border-ink bg-ink px-4 py-2 font-mono text-xs uppercase tracking-[0.16em] text-white"
            type="submit"
          >
            Search
          </button>
        </div>
        <div class="mt-4 flex flex-wrap gap-2" aria-label="Canned factory questions">
          {cannedQuestions.map((question) => (
            <button
              class="focus-ring border border-line px-3 py-2 text-left text-xs font-semibold text-stone-700 hover:border-accent hover:text-accent"
              type="button"
              data-qa-question={question}
            >
              {question}
            </button>
          ))}
        </div>
      </form>

      <div class="qa-output border border-line bg-white p-5" data-qa-output aria-live="polite"></div>
    </div>
  </div>
</section>

<script id="factory-qa-index" type="application/json" set:html={serializedIndex}></script>

<script is:inline>
  (() => {
    const root = document.querySelector("[data-factory-qa]");
    const indexNode = document.getElementById("factory-qa-index");
    if (!root || !indexNode) return;

    const index = JSON.parse(indexNode.textContent || "{}");
    const form = root.querySelector("[data-qa-form]");
    const input = root.querySelector("[data-qa-input]");
    const output = root.querySelector("[data-qa-output]");
    const buttons = root.querySelectorAll("[data-qa-question]");

    const stopwords = new Set([
      "a", "an", "and", "are", "as", "at", "be", "by", "for", "from", "have",
      "how", "in", "is", "it", "of", "on", "or", "our", "should", "the",
      "to", "we", "what", "where", "which", "who", "why", "with"
    ]);
    const expansions = {
      blocked: ["blocker", "blockers", "credential", "credentials", "secret"],
      build: ["queue", "wave", "requirements", "first"],
      cdcp: ["cognitive", "delivery", "control", "plane", "cdcp"],
      credential: ["credentials", "blocker", "blockers", "secret", "key"],
      credentials: ["credential", "blocker", "blockers", "secret", "key"],
      factory: ["factory", "control", "tower", "repo", "repos"],
      mcp: ["mcp", "mcp-security-lab", "security", "lab"],
      new: ["19", "20", "mcp", "trace", "eval", "harness", "door"],
      next: ["queue", "wave", "requirements", "first"],
      repo: ["repo", "repos"],
      repos: ["repo", "repos"]
    };
    const tokenPattern = /[A-Za-z0-9]+(?:[-_][A-Za-z0-9]+)*/g;

    const escapeHtml = (value) =>
      String(value ?? "")
        .replace(/&/g, "&amp;")
        .replace(/</g, "&lt;")
        .replace(/>/g, "&gt;")
        .replace(/"/g, "&quot;")
        .replace(/'/g, "&#39;");

    const tokenize = (text, dropStopwords = false) => {
      const raw = String(text ?? "").toLowerCase().match(tokenPattern) || [];
      const tokens = [];
      raw.forEach((match) => {
        const normalized = match.replace(/_/g, "-");
        const candidates = [normalized, ...normalized.split("-").filter(Boolean)];
        candidates.forEach((candidate) => {
          if (dropStopwords && stopwords.has(candidate)) return;
          tokens.push(candidate);
          if (candidate.length > 3 && candidate.endsWith("s")) {
            const singular = candidate.slice(0, -1);
            if (!dropStopwords || !stopwords.has(singular)) tokens.push(singular);
          }
        });
      });
      return tokens;
    };

    const expandedQueryTokens = (question) => {
      const tokens = tokenize(question, true);
      const expanded = new Set(tokens);
      tokens.forEach((token) => (expansions[token] || []).forEach((item) => expanded.add(item)));
      return Array.from(expanded);
    };

    const scoreChunk = (chunk, question, queryTokens) => {
      const chunkTokens = new Set(chunk.tokens || []);
      const searchText = [
        chunk.path || "",
        chunk.title || "",
        chunk.locator || "",
        chunk.snippet || ""
      ].join(" ").toLowerCase();
      let score = 0;
      queryTokens.forEach((token) => {
        if (chunkTokens.has(token)) score += 3;
        if (token && searchText.includes(token)) score += 1;
      });

      const rawTokens = tokenize(question, true);
      const rawSet = new Set(rawTokens);
      for (let index = 0; index < rawTokens.length - 1; index += 1) {
        const phrase = `${rawTokens[index]} ${rawTokens[index + 1]}`;
        const hyphenPhrase = `${rawTokens[index]}-${rawTokens[index + 1]}`;
        if (searchText.includes(phrase) || searchText.includes(hyphenPhrase)) score += 5;
      }

      const path = chunk.path || "";
      const title = String(chunk.title || "").toLowerCase();
      const snippet = String(chunk.snippet || "");
      const hasAny = (...terms) => terms.some((term) => rawSet.has(term));
      if (hasAny("build", "next") && path === "ops/factory-build-queue.md") score += 8;
      if (hasAny("credential", "credentials", "blocked")) {
        if (path === "ops/factory-build-queue.md") score += 5;
        if (searchText.includes("credential blockers")) score += 12;
      }
      if (rawSet.has("cdcp") && hasAny("repo", "repos")) {
        if (path === "ops/portfolio-health.md" && title.includes("cdcp status")) score += 18;
        if (path === "src/data/factory-snapshot.json" && snippet.includes("CDCP status")) score += 8;
      }
      if (rawSet.has("mcp") && rawSet.has("security") && rawSet.has("lab")) {
        if (path === "src/content/doors.json") score += 16;
        if (searchText.includes("mcp-security-lab")) score += 5;
      }
      if (rawSet.has("new") && rawSet.has("factory") && hasAny("repo", "repos")) {
        if (["src/data/factory-snapshot.json", "src/content/doors.json"].includes(path)) {
          if (snippet.includes("Door 19") || snippet.includes("Door 20")) score += 16;
        }
      }
      return score;
    };

    const answerQuestion = (question) => {
      const queryTokens = expandedQueryTokens(question);
      if (!queryTokens.length) return { status: "empty", results: [] };
      const results = (index.chunks || [])
        .map((chunk) => ({ chunk, score: scoreChunk(chunk, question, queryTokens) }))
        .filter((item) => item.score >= 6)
        .sort((left, right) => right.score - left.score || (left.chunk.order || 0) - (right.chunk.order || 0))
        .slice(0, 5)
        .map((item) => ({ ...item.chunk, score: item.score }));
      return results.length
        ? { status: "cited", results }
        : { status: "not_enough_evidence", results: [] };
    };

    const renderResult = (result) => `
      <li class="qa-result">
        <p class="qa-result-title">${escapeHtml(result.title)}</p>
        <p class="qa-snippet">${escapeHtml(result.snippet)}</p>
        <p class="qa-citation">
          <code>${escapeHtml(result.path)}</code>${result.locator ? ` <span>${escapeHtml(result.locator)}</span>` : ""}
        </p>
      </li>
    `;

    const runSearch = (question) => {
      const trimmed = String(question || "").trim();
      if (!trimmed) {
        output.innerHTML = "";
        return;
      }
      const answer = answerQuestion(trimmed);
      if (answer.status !== "cited") {
        output.innerHTML = '<p class="qa-empty">Not enough evidence in the static index.</p>';
        return;
      }
      output.innerHTML = `
        <p class="qa-kicker">Cited snippets</p>
        <ol class="qa-results">${answer.results.map(renderResult).join("")}</ol>
      `;
    };

    form.addEventListener("submit", (event) => {
      event.preventDefault();
      runSearch(input.value);
    });
    buttons.forEach((button) => {
      button.addEventListener("click", () => {
        input.value = button.dataset.qaQuestion || "";
        runSearch(input.value);
      });
    });
  })();
</script>

<style>
  .qa-output {
    min-height: 15rem;
  }

  .qa-empty {
    font-size: 1.4rem;
    font-weight: 650;
    line-height: 1.25;
  }

  .qa-kicker,
  .qa-citation {
    font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", monospace;
    font-size: 0.7rem;
    letter-spacing: 0.14em;
    text-transform: uppercase;
    color: rgb(87 83 78);
  }

  .qa-results {
    margin-top: 1rem;
    display: grid;
    gap: 1rem;
  }

  .qa-result {
    border-top: 1px solid var(--line);
    padding-top: 1rem;
  }

  .qa-result-title {
    font-weight: 650;
  }

  .qa-snippet {
    margin-top: 0.5rem;
    line-height: 1.7;
    color: rgb(68 64 60);
  }

  .qa-citation {
    margin-top: 0.75rem;
    overflow-wrap: anywhere;
  }
</style>
