---
interface Door {
  n: string;
  name: string;
  status: "active" | "solved" | "drawer";
  url: string;
  hook: string;
}

const { door } = Astro.props as { door: Door };

const statusStyles = {
  active: "border-accent text-accent",
  solved: "border-stone-500 text-stone-700",
  drawer: "border-stone-300 text-stone-500"
};
---

<article
  class="door-card flex min-h-72 flex-col justify-between border border-line bg-white p-5"
  data-status={door.status}
>
  <div>
    <div class="flex items-start justify-between gap-4">
      <p class="font-mono text-sm text-stone-500">No. {door.n}</p>
      <span class:list={["rounded-full border px-2.5 py-1 font-mono text-[0.65rem] uppercase tracking-[0.16em]", statusStyles[door.status]]}>
        {door.status}
      </span>
    </div>
    <h3 class="mt-6 break-words text-xl font-semibold leading-7">
      <a class="focus-ring no-underline" href={door.url} target="_blank" rel="noreferrer">{door.name}</a>
    </h3>
    <p class="mt-4 text-sm leading-6 text-stone-700">{door.hook}</p>
  </div>
  <a class="focus-ring mt-8 inline-flex text-sm font-semibold no-underline" href={door.url} target="_blank" rel="noreferrer">
    View repository
  </a>
</article>
