{
  "name": "athena-mcp-server",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "description": "Read-only MCP server exposing the athena-site portfolio's authoritative model (decisions, schemas, runs, events).",
  "main": "dist/index.js",
  "bin": {
    "athena-mcp-server": "dist/index.js"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "start": "node dist/index.js",
    "test": "node --test --import tsx tests/*.test.ts",
    "snapshot": "tsx scripts/snapshot-tool-surface.ts"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4"
  },
  "devDependencies": {
    "@types/node": "^22.10.0",
    "tsx": "^4.19.0",
    "typescript": "^5.6.0"
  },
  "engines": {
    "node": ">=20"
  }
}
